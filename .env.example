# sftlogapi v2 - Docker Compose 环境变量文件
# 复制此文件为 .env 并填写实际值
# 使用方法：docker-compose --env-file .env -f docker-compose.prod.yml up -d

# ========== API 配置 ==========
# 生成安全的 API Key: openssl rand -hex 32
API_KEY=

# 是否启用 API 认证 (true/false)
ENABLE_AUTH=true

# ========== 其他配置（通常无需修改）==========
DEBUG=false
HOST=0.0.0.0
PORT=5000
CACHE_TTL=3600
CACHE_MAX_SIZE=10000
