# sftlogapi v2 - 本地敏感信息配置示例
# 复制此文件为 .env.local 并填写实际值
# 注意：.env.local 已添加到 .gitignore，不会被提交

# ========== 跳板机配置 ==========
JUMP_HOST="192.168.13.104"
JUMP_USER="root"
JUMP_PASS="your_jump_host_password"

# ========== 中间机配置 ==========
MIDDLE_HOST="192.168.109.75"
MIDDLE_USER="sftuser"
MIDDLE_PASS="your_middle_host_password"

# ========== 后端主机配置 ==========
BACKEND_HOST="192.168.109.77"
BACKEND_USER="sftuser"
BACKEND_PASS="your_backend_host_password"
BACKEND_DIR="/app/sftlogapi-root/sftlogapi-v2"

# ========== 前端主机配置 ==========
FRONTEND_HOST="192.168.109.54"
FRONTEND_USER="sftuser"
FRONTEND_PASS="your_frontend_host_password"
FRONTEND_DIR="/app/tengine/frontend"

# ========== API Key ==========
API_KEY="your_generated_api_key"
