# sftlogapi v2 配置文件示例
# 复制此文件为 config.env 并修改为实际路径

# ========== 日志配置 ==========
# 日志文件根目录（宿主机路径）
LOG_BASE_DIR=/root/sft/testlogs

# ========== 数据库配置 ==========
# SQLite 数据库路径（宿主机路径）
DB_PATH=/root/sft-data/index/logs_trace.db

# ========== API 配置 ==========
# API Key 认证密钥（必须设置，建议使用 openssl rand -hex 32 生成）
API_KEY=<YOUR_SECURE_API_KEY_HERE>

# 是否启用 API 认证 (true/false)
# 注意：启用认证前必须设置 API_KEY
ENABLE_AUTH=false

# ========== 服务配置 ==========
# Flask 服务端口
PORT=5000

# Flask 服务地址
HOST=0.0.0.0

# 调试模式 (true/false)
DEBUG=false

# ========== 缓存配置 ==========
# 缓存过期时间（秒）
CACHE_TTL=3600

# 缓存最大条目数
CACHE_MAX_SIZE=10000

# ========== 定时任务配置 ==========
# 压缩脚本2 脚本目录
SCRIPTS_DIR=/root/sft/sftlogapi-v2/scripts

# 日志保留天数
RETENTION_DAYS=7

# ========== 容器配置 ==========
# Docker 容器名称
CONTAINER_NAME=sftlogapi-v2

# Docker 镜像名称
DOCKER_IMAGE=sftlogapi:v2

# 容器内日志目录（不要修改）
CONTAINER_LOG_DIR=/data/logs

# 容器内数据库目录（不要修改）
CONTAINER_DB_DIR=/data/index
